))\nprint(\"Classes:\", list(le.classes_))\nprint(\"\\nX shape:\", X.shape)\nprint(\"y shape:\", y.shape)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-31T11:28:55.127172Z","iopub.execute_input":"2026-03-31T11:28:55.128063Z","iopub.status.idle":"2026-03-31T11:28:55.141529Z","shell.execute_reply.started":"2026-03-31T11:28:55.128032Z","shell.execute_reply":"2026-03-31T11:28:55.140155Z"}},"outputs":[{"name":"stdout","text":"Features: 28\nTarget classes: 22\nClasses: ['Arts/Media', 'Building/Grounds', 'Business/Finance', 'Computer/IT', 'Construction', 'Education', 'Engineering', 'Farming', 'Food Service', 'Healthcare', 'Healthcare Support', 'Legal', 'Maintenance', 'Management', 'Office/Admin', 'Personal Care', 'Production', 'Protective Services', 'Sales', 'Science', 'Social Services', 'Transportation']\n\nX shape: (873, 28)\ny shape: (873,)\n","output_type":"stream"}],"execution_count":3},{"cell_type":"markdown","source":"We have 28 features and 22 career categories as our target. The Category \ncolumn is label encoded into numeric form for use with all importance \nalgorithms. The original Category column is kept for reference.","metadata":{}},{"cell_type":"markdown","source":"## 2. Feature Importance — 5 Algorithms\n\n### 2.1 Random Forest Importance","metadata":{}},{"cell_type":"code","source":"rf = RandomForestClassifier(n_estimators=100, random_state=42)\nrf.fit(X, y)\n\nrf_importance = pd.DataFrame({\n    'Feature': feature_cols,\n    'Importance': rf.feature_importances_\n}).sort_values('Importance', ascending=False)\n\nplt.figure(figsize=(12, 8))\nsns.barplot(data=rf_importance, x='Importance', y='Feature', palette='viridis')\nplt.title(\"Random Forest — Feature Importance\")\nplt.tight_layout()\nplt.show()\n\nprint(rf_importance.to_string())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-31T11:28:55.142672Z","iopub.execute_input":"2026-03-31T11:28:55.143130Z","iopub.status.idle":"2026-03-31T11:28:56.376135Z","shell